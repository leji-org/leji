---
// The circle: people and agents read one shared context layer, propose changes,
// and people approve. A single SVG panel, styled for the light page.
---

<div class="circle-chart">
   <svg
      class="cc-panel cc-circle"
      viewBox="467 22 506 384"
      role="img"
      aria-label="Leji: a circle. People and agents read one shared context layer; agents propose changes and people approve them; staleness is felt and fixed."
   >
      <defs>
         <marker
            id="cc-arrow-r"
            viewBox="0 0 10 10"
            refX="9"
            refY="5"
            markerUnits="userSpaceOnUse"
            markerWidth="11"
            markerHeight="11"
            orient="auto-start-reverse"
         >
            <path d="M 0 0 L 10 5 L 0 10 z" fill="#223F93"></path>
         </marker>
      </defs>

      <text x="720" y="46" class="panel-title">Leji: a circle</text>

      <circle cx="720" cy="210" r="118" class="ring"></circle>

      <g class="spokes">
         <line
            x1="650"
            y1="145"
            x2="687"
            y2="179"
            class="spoke"
            marker-start="url(#cc-arrow-r)"
            marker-end="url(#cc-arrow-r)"></line>
         <line
            x1="790"
            y1="145"
            x2="753"
            y2="179"
            class="spoke"
            marker-start="url(#cc-arrow-r)"
            marker-end="url(#cc-arrow-r)"></line>
         <line
            x1="650"
            y1="275"
            x2="687"
            y2="241"
            class="spoke"
            marker-start="url(#cc-arrow-r)"
            marker-end="url(#cc-arrow-r)"></line>
         <line
            x1="790"
            y1="275"
            x2="753"
            y2="241"
            class="spoke"
            marker-start="url(#cc-arrow-r)"
            marker-end="url(#cc-arrow-r)"></line>
         <circle r="4.5" class="spoke-dot">
            <animateMotion
               dur="2.9s"
               repeatCount="indefinite"
               calcMode="linear"
               keyPoints="0;1;0"
               keyTimes="0;0.5;1"
               path="M650,145 L687,179"></animateMotion>
         </circle>
         <circle r="4.5" class="spoke-dot">
            <animateMotion
               dur="3.7s"
               repeatCount="indefinite"
               calcMode="linear"
               keyPoints="0;1;0"
               keyTimes="0;0.5;1"
               path="M790,145 L753,179"></animateMotion>
         </circle>
         <circle r="4.5" class="spoke-dot">
            <animateMotion
               dur="3.2s"
               repeatCount="indefinite"
               calcMode="linear"
               keyPoints="0;1;0"
               keyTimes="0;0.5;1"
               path="M650,275 L687,241"></animateMotion>
         </circle>
         <circle r="4.5" class="spoke-dot">
            <animateMotion
               dur="4.1s"
               repeatCount="indefinite"
               calcMode="linear"
               keyPoints="0;1;0"
               keyTimes="0;0.5;1"
               path="M790,275 L753,241"></animateMotion>
         </circle>
      </g>

      <circle cx="720" cy="210" r="52" class="core"></circle>
      <text x="720" y="196" class="core-label">shared</text>
      <text x="720" y="213" class="core-label">context</text>
      <text x="720" y="230" class="core-label">layer</text>

      <circle cx="628" cy="122" r="32" class="node human"></circle>
      <text x="628" y="127" class="node-label">People</text>
      <circle cx="812" cy="122" r="32" class="node human"></circle>
      <text x="812" y="127" class="node-label">People</text>
      <circle cx="628" cy="298" r="32" class="node agent"></circle>
      <text x="628" y="303" class="node-label">Agents</text>
      <circle cx="812" cy="298" r="32" class="node agent"></circle>
      <text x="812" y="303" class="node-label">Agents</text>

      <text x="720" y="368" class="legend">human-to-human · human-to-AI · human-to-AI-to-human</text>
      <text x="720" y="390" class="caption"
         >Everyone reads; anyone proposes; people approve. Staleness is felt and fixed.</text
      >
   </svg>
</div>

<style>
   .circle-chart {
      display: flex;
      justify-content: start;
   }
   .cc-panel {
      width: 100%;
      max-width: 26rem;
      height: auto;
      display: block;
   }
   .panel-title {
      font-family: var(--mono);
      font-size: 13.5px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      fill: var(--blue);
      text-anchor: middle;
   }
   .spoke {
      stroke: var(--blue);
      stroke-width: 1.7;
   }
   .ring {
      fill: none;
      stroke: rgba(34, 63, 147, 0.4);
      stroke-width: 1.3;
      stroke-dasharray: 5 6;
      animation: cc-ring 4.5s linear infinite;
   }
   /* spokes stay solid (an unbroken connection); gold particles drift along
      them, fading in and out, each at its own tempo so nothing pulses in lockstep */
   .spoke-dot {
      fill: var(--gold);
      animation: cc-dot 3s ease-in-out infinite;
   }
   .spokes circle:nth-of-type(1) {
      animation-duration: 2.6s;
      animation-delay: -0.3s;
   }
   .spokes circle:nth-of-type(2) {
      animation-duration: 3.5s;
      animation-delay: -1.1s;
   }
   .spokes circle:nth-of-type(3) {
      animation-duration: 3.1s;
      animation-delay: -0.6s;
   }
   .spokes circle:nth-of-type(4) {
      animation-duration: 4s;
      animation-delay: -1.7s;
   }
   .core {
      fill: var(--gold);
   }
   @keyframes cc-dot {
      0%,
      100% {
         opacity: 0.25;
      }
      50% {
         opacity: 1;
      }
   }
   @keyframes cc-ring {
      to {
         stroke-dashoffset: -11;
      }
   }
   @media (prefers-reduced-motion: reduce) {
      .ring {
         animation: none;
      }
      .spoke-dot {
         display: none;
      }
   }
   .core-label {
      font-family: var(--mono);
      font-size: 14px;
      font-weight: 500;
      fill: var(--blue-deep);
      text-anchor: middle;
   }
   .node {
      fill: var(--blue-deep);
      stroke-width: 1.5;
   }
   .node.human {
      stroke: var(--blue-soft);
   }
   .node.agent {
      stroke: var(--gold);
   }
   .node-label {
      font-family: var(--mono);
      font-size: 12.5px;
      fill: var(--white);
      text-anchor: middle;
   }
   .legend {
      font-family: var(--mono);
      font-size: 13px;
      font-weight: 500;
      fill: var(--blue);
      text-anchor: middle;
   }
   .caption {
      font-family: var(--serif-text);
      font-size: 13px;
      fill: var(--ink-soft);
      text-anchor: middle;
   }
</style>
