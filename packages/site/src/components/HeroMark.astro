---
// Animated hero icon: cover circles over the three node rings shrink away on load, revealing the rings outside-in.
import svg from '../assets/leji-icon.svg?raw';

const { size = 150, loop = false } = Astro.props;
const width = Math.round((size * 370) / 391);

const iconPath = /d="([^"]+)"/.exec(svg)![1];

// Ring centers from the icon geometry; cover r=43 hides a ring, scaled to 0.26 it tucks into the hole.
const nodes = [
   { cx: 185.05, cy: 118.61 }, // center, under the capital
   { cx: 258.78, cy: 249.62 }, // right trace
   { cx: 111.26, cy: 349.48 }, // left trace, lowest
];
---

<svg
   class:list={['hero-mark-svg', { loop }]}
   width={width}
   height={size}
   viewBox="0 0 370 391"
   fill="none"
   role="img"
   aria-label="Leji mark: a classical column whose flutes are circuit traces ending in nodes"
>
   <path d={iconPath} fill="#FFBD6E"></path>
   {nodes.map(({ cx, cy }, i) => <circle class={`cover c${i + 1}`} cx={cx} cy={cy} r="43" fill="var(--blue-deep)" />)}
</svg>

<style>
   .cover {
      transform-box: fill-box;
      transform-origin: center;
      animation: conceal 0.5s cubic-bezier(0.5, 0, 0.2, 1) forwards;
   }
   .c1 {
      animation-delay: 0.55s;
   }
   .c2 {
      animation-delay: 0.75s;
   }
   .c3 {
      animation-delay: 0.95s;
   }

   @keyframes conceal {
      to {
         transform: scale(0.26);
      }
   }

   /* looping variant: the circuit nodes reveal outside-in, hold, then re-cover
      and repeat. Covers are blue-deep, so over a blue-deep surface (the
      terminal) the conceal/reveal reads as the nodes powering on and off. */
   .loop .cover {
      animation: conceal-loop 3.6s ease-in-out infinite;
   }
   /* each node breathes at its own tempo, so they drift in and out of phase */
   .loop .c1 {
      animation-duration: 3.4s;
      animation-delay: -0.2s;
   }
   .loop .c2 {
      animation-duration: 4.7s;
      animation-delay: -1.6s;
   }
   .loop .c3 {
      animation-duration: 2.9s;
      animation-delay: -0.9s;
   }
   /* gently breathe between revealed (0.26) and half-covered (0.62); the covers
      never grow back to a full blue circle, so the nodes stay partly lit */
   @keyframes conceal-loop {
      0%,
      100% {
         transform: scale(0.26);
      }
      50% {
         transform: scale(0.62);
      }
   }
   @media (prefers-reduced-motion: reduce) {
      .cover {
         display: none;
      }
   }
</style>
