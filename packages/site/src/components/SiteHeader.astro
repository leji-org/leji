---
// The one site header: the monument's architrave. Deep-blue band with a gold
// line beneath, mirroring the footer plinth. Wordmark renders white on the
// blue, per the brand rule. `flush` drops the band's own background and gold
// line for pages where the header sits inside the monument (the landing page).
import LejiLogo from './LejiLogo.astro';
const { flush = false } = Astro.props;

// Section-aware active state: the reference pages live in the spec reading
// room, and the adoption guides are where Get Started hands off to.
const path = Astro.url.pathname;
const active = (...prefixes: string[]) => (prefixes.some((p) => path.startsWith(p)) ? 'page' : undefined);
---

<header class:list={['site-header-band', { flush }]}>
   <div class="wrap header-row">
      <a class="brand" href="/" aria-label="Leji home"><LejiLogo height={30} /></a>
      <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Open menu">
         <span class="bars" aria-hidden="true"></span>
      </button>
      <nav id="site-nav">
         <a href="/spec/" aria-current={active('/spec/')}>Spec</a>
         <a href="/quickstart/" aria-current={active('/quickstart/')}>Quickstart</a>
         <div class="nav-group">
            <a
               href="/manifest/"
               class="nav-trigger"
               aria-haspopup="true"
               aria-current={active('/manifest/', '/schemas/', '/cli/')}
            >
               Reference <span class="caret" aria-hidden="true">›</span>
            </a>
            <div class="nav-menu">
               <a href="/manifest/">Manifest</a>
               <a href="/schemas/">Schemas</a>
               <a href="/cli/">CLI</a>
            </div>
         </div>
         <a href="/rationale/" aria-current={active('/rationale/')}>Rationale</a>
         <a
            class="source-link"
            href="https://github.com/leji-org/leji"
            target="_blank"
            rel="noopener"
            aria-label="Source repository on GitHub"
         >
            <svg aria-hidden="true" viewBox="0 0 98 96" width="14" height="14" xmlns="http://www.w3.org/2000/svg"
               ><path
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d="M41.4395 69.3848C28.8066 67.8535 19.9062 58.7617 19.9062 46.9902C19.9062 42.2051 21.6289 37.0371 24.5 33.5918C23.2559 30.4336 23.4473 23.7344 24.8828 20.959C28.7109 20.4805 33.8789 22.4902 36.9414 25.2656C40.5781 24.1172 44.4062 23.543 49.0957 23.543C53.7852 23.543 57.6133 24.1172 61.0586 25.1699C64.0254 22.4902 69.2891 20.4805 73.1172 20.959C74.457 23.543 74.6484 30.2422 73.4043 33.4961C76.4668 37.1328 78.0937 42.0137 78.0937 46.9902C78.0937 58.7617 69.1934 67.6621 56.3691 69.2891C59.623 71.3945 61.8242 75.9883 61.8242 81.252L61.8242 91.2051C61.8242 94.0762 64.2168 95.7031 67.0879 94.5547C84.4102 87.9512 98 70.6289 98 49.1914C98 22.1074 75.9883 0 48.9043 0C21.8203 0 0 22.1074 0 49.1914C0 70.4375 13.4941 88.0469 31.6777 94.6504C34.2617 95.6074 36.75 93.8848 36.75 91.3008L36.75 83.6445C35.4102 84.2188 33.6875 84.6016 32.1562 84.6016C25.8398 84.6016 22.1074 81.1563 19.4277 74.7441C18.375 72.1602 17.2266 70.6289 15.0254 70.3418C13.877 70.2461 13.4941 69.7676 13.4941 69.1934C13.4941 68.0449 15.4082 67.1836 17.3223 67.1836C20.0977 67.1836 22.4902 68.9063 24.9785 72.4473C26.8926 75.2227 28.9023 76.4668 31.2949 76.4668C33.6875 76.4668 35.2187 75.6055 37.4199 73.4043C39.0469 71.7773 40.291 70.3418 41.4395 69.3848Z"
                  fill="currentColor"></path></svg
            >
         </a>
      </nav>
   </div>
</header>

<style>
   .site-header-band {
      border-bottom: 3px solid var(--gold);
      background: var(--blue-deep);
      color: var(--white);
      position: relative;
      /* no overflow:hidden here: it would clip the Reference dropdown. The
         fluting ::before is inset:0, so it never overflows the band anyway. */
   }
   .site-header-band::before {
      /* the monument's fluting, same as the plinth */
      content: '';
      position: absolute;
      inset: 0;
      background-image: repeating-linear-gradient(90deg, transparent 0 78px, rgba(255, 189, 110, 0.05) 78px 79px);
      pointer-events: none;
   }
   .site-header-band > * {
      position: relative;
   }
   .site-header-band.flush {
      border-bottom: none;
      background: transparent;
   }
   .site-header-band.flush::before {
      content: none;
   }
   .header-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.8rem 1.5rem;
      padding-top: 1.05rem;
      padding-bottom: 1.05rem;
   }
   .brand {
      color: var(--white);
      display: inline-flex;
   }
   .nav-toggle {
      display: none;
      align-items: center;
      justify-content: center;
      width: 2.4rem;
      height: 2.4rem;
      margin: -0.5rem -0.5rem -0.5rem 0;
      padding: 0;
      background: none;
      border: none;
      color: var(--white);
      cursor: pointer;
   }
   .bars,
   .bars::before,
   .bars::after {
      display: block;
      width: 22px;
      height: 2px;
      background: currentColor;
      transition:
         transform 0.2s ease,
         opacity 0.15s ease;
   }
   .bars {
      position: relative;
   }
   .bars::before,
   .bars::after {
      content: '';
      position: absolute;
      left: 0;
   }
   .bars::before {
      top: -7px;
   }
   .bars::after {
      top: 7px;
   }
   .nav-toggle[aria-expanded='true'] .bars {
      background: transparent;
   }
   .nav-toggle[aria-expanded='true'] .bars::before {
      transform: translateY(7px) rotate(45deg);
   }
   .nav-toggle[aria-expanded='true'] .bars::after {
      transform: translateY(-7px) rotate(-45deg);
   }
   nav {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.6rem 1.6rem;
      font-family: var(--mono);
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
   }
   nav a {
      white-space: nowrap;
   }
   .source-link {
      display: inline-flex;
      align-items: center;
      gap: 0.45em;
   }
   .source-link svg {
      display: block;
      transform: translateY(-1px);
   }
   nav a {
      color: var(--white-soft);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      padding-bottom: 2px;
      transition:
         color 0.2s,
         border-color 0.2s;
   }
   nav a:hover {
      color: var(--gold-bright);
      border-color: var(--gold);
   }
   nav a[aria-current='page'] {
      color: var(--gold-bright);
   }

   /* Reference dropdown */
   .nav-group {
      position: relative;
      display: inline-flex;
   }
   /* same chevron glyph as the sidebar groups, rotated down to read as a
      dropdown; turns fully on open to match the sidebar's open state */
   .caret {
      display: inline-block;
      font-size: 1.15em;
      transform: rotate(90deg);
      transition: transform 0.15s;
   }
   .nav-group:hover .caret,
   .nav-group:focus-within .caret {
      transform: rotate(270deg);
   }
   .nav-menu {
      position: absolute;
      top: calc(100% + 0.7rem);
      left: 0;
      min-width: 10rem;
      display: none;
      flex-direction: column;
      gap: 0.15rem;
      padding: 0.5rem;
      background: var(--white);
      border: 1px solid var(--paper-edge);
      border-radius: 10px;
      box-shadow: 0 14px 34px rgba(22, 41, 96, 0.22);
      z-index: 30;
   }
   /* keep the menu open while crossing the gap from trigger to menu */
   .nav-group:hover::after {
      content: '';
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      height: 0.7rem;
   }
   .nav-group:hover .nav-menu,
   .nav-group:focus-within .nav-menu {
      display: flex;
   }
   .nav-menu a {
      color: var(--ink-soft);
      text-transform: none;
      letter-spacing: 0.01em;
      font-size: 0.82rem;
      padding: 0.4rem 0.7rem;
      border-radius: 5px;
      border-bottom: none;
   }
   .nav-menu a:hover {
      color: var(--blue-deep);
      background: rgba(34, 63, 147, 0.07);
      border-color: transparent;
   }

   @media (prefers-reduced-motion: reduce) {
      .bars,
      .bars::before,
      .bars::after {
         transition: none;
      }
   }

   /* Mobile: collapse the nav behind the hamburger. Placed last so these rules
      win on source order over the desktop dropdown base rules above (media
      queries add no specificity). */
   @media (max-width: 600px) {
      .nav-toggle {
         display: inline-flex;
      }
      nav {
         display: none;
         flex-basis: 100%;
         flex-direction: column;
         align-items: stretch;
         gap: 0;
         padding-top: 0.4rem;
      }
      nav[data-open] {
         display: flex;
      }
      nav > a,
      .nav-trigger {
         width: 100%;
         padding: 0.75rem 0;
         border-bottom: 1px solid rgba(255, 189, 110, 0.12);
      }
      .source-link {
         border-bottom: none;
      }
      .nav-group {
         display: block;
         width: 100%;
      }
      .caret {
         display: none;
      }
      /* the Reference children read as an indented sub-list inside the band,
         always visible on touch (no hover state to rely on) */
      .nav-menu {
         position: static;
         display: flex;
         min-width: 0;
         padding: 0.1rem 0 0.5rem 1.1rem;
         background: transparent;
         border: none;
         border-radius: 0;
         box-shadow: none;
      }
      .nav-menu a {
         color: var(--white-soft);
         text-transform: uppercase;
         letter-spacing: 0.08em;
         font-size: 0.72rem;
         padding: 0.5rem 0;
      }
      .nav-menu a:hover {
         color: var(--gold-bright);
         background: transparent;
      }
   }
</style>

<script>
   const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
   const nav = document.getElementById('site-nav');

   if (toggle && nav) {
      const close = () => {
         nav.removeAttribute('data-open');
         toggle.setAttribute('aria-expanded', 'false');
         toggle.setAttribute('aria-label', 'Open menu');
      };
      const open = () => {
         nav.setAttribute('data-open', '');
         toggle.setAttribute('aria-expanded', 'true');
         toggle.setAttribute('aria-label', 'Close menu');
      };

      toggle.addEventListener('click', () => {
         nav.hasAttribute('data-open') ? close() : open();
      });

      // tapping a destination closes the menu
      nav.addEventListener('click', (e) => {
         if ((e.target as HTMLElement).closest('a')) close();
      });

      // Escape closes; focus returns to the toggle
      document.addEventListener('keydown', (e) => {
         if (e.key === 'Escape' && nav.hasAttribute('data-open')) {
            close();
            toggle.focus();
         }
      });

      // crossing back to the desktop layout resets state
      const desktop = window.matchMedia('(min-width: 601px)');
      desktop.addEventListener('change', (e) => {
         if (e.matches) close();
      });
   }
</script>
