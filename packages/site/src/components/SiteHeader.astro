---
// Site header. `flush` drops the band background and gold line where the header sits inside the monument (the landing page).
import LejiLogo from './LejiLogo.astro';
import githubIcon from '../assets/github.svg?raw';
const { flush = false } = Astro.props;

// Section-aware active state across the reference and adoption sections.
const path = Astro.url.pathname;
const active = (...prefixes: string[]) => (prefixes.some((p) => path.startsWith(p)) ? 'page' : undefined);
---

<header class:list={['site-header-band', { flush }]}>
   <div class="wrap header-row">
      <a class="brand" href="/" aria-label="Leji home"><LejiLogo height={30} /></a>
      <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Open menu">
         <span class="bars" aria-hidden="true"></span>
      </button>
      <nav id="site-nav">
         <a href="/spec/" aria-current={active('/spec/')}>Spec</a>
         <a href="/quickstart/" aria-current={active('/quickstart/')}>Quickstart</a>
         <div class="nav-group">
            <a
               href="/manifest/"
               class="nav-trigger"
               aria-haspopup="true"
               aria-current={active('/manifest/', '/schemas/', '/cli/', '/mcp/')}
            >
               Reference <span class="caret" aria-hidden="true">›</span>
            </a>
            <div class="nav-menu">
               <a href="/manifest/">Manifest</a>
               <a href="/schemas/">Schemas</a>
               <a href="/cli/">CLI</a>
               <a href="/mcp/">MCP server</a>
            </div>
         </div>
         <a href="/rationale/" aria-current={active('/rationale/')}>Rationale</a>
         <a
            class="source-link"
            href="https://github.com/leji-org/leji"
            target="_blank"
            rel="noopener"
            aria-label="Source repository on GitHub"
         >
            Source
            <span class="gh-icon" set:html={githubIcon} />
         </a>
      </nav>
   </div>
</header>

<style>
   .site-header-band {
      border-bottom: 3px solid var(--gold);
      background: var(--blue-deep);
      color: var(--white);
      position: relative;
      /* no overflow:hidden here: it would clip the Reference dropdown. The
         fluting ::before is inset:0, so it never overflows the band anyway. */
   }
   .site-header-band::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: repeating-linear-gradient(90deg, transparent 0 78px, rgba(255, 189, 110, 0.05) 78px 79px);
      pointer-events: none;
   }
   .site-header-band > * {
      position: relative;
   }
   .site-header-band.flush {
      border-bottom: none;
      background: transparent;
   }
   .site-header-band.flush::before {
      content: none;
   }
   .header-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.8rem 1.5rem;
      padding-top: 1.05rem;
      padding-bottom: 1.05rem;
   }
   .brand {
      color: var(--white);
      display: inline-flex;
   }
   .nav-toggle {
      display: none;
      align-items: center;
      justify-content: center;
      width: 2.4rem;
      height: 2.4rem;
      margin: -0.5rem -0.5rem -0.5rem 0;
      padding: 0;
      background: none;
      border: none;
      color: var(--white);
      cursor: pointer;
   }
   .bars,
   .bars::before,
   .bars::after {
      display: block;
      width: 22px;
      height: 2px;
      background: currentColor;
      transition:
         transform 0.2s ease,
         opacity 0.15s ease;
   }
   .bars {
      position: relative;
   }
   .bars::before,
   .bars::after {
      content: '';
      position: absolute;
      left: 0;
   }
   .bars::before {
      top: -7px;
   }
   .bars::after {
      top: 7px;
   }
   .nav-toggle[aria-expanded='true'] .bars {
      background: transparent;
   }
   .nav-toggle[aria-expanded='true'] .bars::before {
      transform: translateY(7px) rotate(45deg);
   }
   .nav-toggle[aria-expanded='true'] .bars::after {
      transform: translateY(-7px) rotate(-45deg);
   }
   nav {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.6rem 1.6rem;
      font-family: var(--mono);
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
   }
   nav a {
      white-space: nowrap;
   }
   .source-link {
      display: inline-flex;
      align-items: center;
      gap: 0.45em;
   }
   .source-link .gh-icon {
      display: inline-flex;
   }
   .source-link .gh-icon :global(svg) {
      display: block;
      height: 14px;
      width: auto;
      transform: translateY(-1px);
   }
   nav a {
      color: var(--white-soft);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      padding-bottom: 2px;
      transition:
         color 0.2s,
         border-color 0.2s;
   }
   nav a:hover {
      color: var(--gold-bright);
      border-color: var(--gold);
   }
   nav a[aria-current='page'] {
      color: var(--gold-bright);
   }

   /* Reference dropdown */
   .nav-group {
      position: relative;
      display: inline-flex;
   }
   /* same chevron glyph as the sidebar groups, rotated down to read as a
      dropdown; turns fully on open to match the sidebar's open state */
   .caret {
      display: inline-block;
      font-size: 1.15em;
      transform: rotate(90deg);
      transition: transform 0.15s;
   }
   .nav-group:hover .caret,
   .nav-group:focus-within .caret {
      transform: rotate(270deg);
   }
   .nav-menu {
      position: absolute;
      top: calc(100% + 0.7rem);
      left: 0;
      min-width: 10rem;
      display: none;
      flex-direction: column;
      gap: 0.15rem;
      padding: 0.5rem;
      background: var(--white);
      border: 1px solid var(--paper-edge);
      border-radius: 10px;
      box-shadow: 0 14px 34px rgba(22, 41, 96, 0.22);
      z-index: 30;
   }
   /* keep the menu open while crossing the gap from trigger to menu */
   .nav-group:hover::after {
      content: '';
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      height: 0.7rem;
   }
   .nav-group:hover .nav-menu,
   .nav-group:focus-within .nav-menu {
      display: flex;
   }
   .nav-menu a {
      color: var(--ink-soft);
      text-transform: none;
      letter-spacing: 0.01em;
      font-size: 0.82rem;
      padding: 0.4rem 0.7rem;
      border-radius: 5px;
      border-bottom: none;
   }
   .nav-menu a:hover {
      color: var(--blue-deep);
      background: rgba(34, 63, 147, 0.07);
      border-color: transparent;
   }

   @media (prefers-reduced-motion: reduce) {
      .bars,
      .bars::before,
      .bars::after {
         transition: none;
      }
   }

   /* Mobile: collapse the nav behind the hamburger. Placed last so these rules
      win on source order over the desktop dropdown base rules above (media
      queries add no specificity). */
   @media (max-width: 630px) {
      .nav-toggle {
         display: inline-flex;
      }
      nav {
         display: none;
         flex-basis: 100%;
         flex-direction: column;
         align-items: stretch;
         gap: 0;
         padding-top: 0.4rem;
      }
      nav[data-open] {
         display: flex;
      }
      nav > a,
      .nav-trigger {
         width: 100%;
         padding: 0.75rem 0;
         border-bottom: 1px solid rgba(255, 189, 110, 0.12);
      }
      .source-link {
         border-bottom: none;
      }
      .nav-group {
         display: block;
         width: 100%;
      }
      .caret {
         display: none;
      }
      /* the Reference children read as an indented sub-list inside the band,
         always visible on touch (no hover state to rely on) */
      .nav-menu {
         position: static;
         display: flex;
         min-width: 0;
         padding: 0.1rem 0 0.5rem 1.1rem;
         background: transparent;
         border: none;
         border-radius: 0;
         box-shadow: none;
      }
      .nav-menu a {
         color: var(--white-soft);
         text-transform: uppercase;
         letter-spacing: 0.08em;
         font-size: 0.72rem;
         padding: 0.5rem 0;
      }
      .nav-menu a:hover {
         color: var(--gold-bright);
         background: transparent;
      }
   }
</style>

<script>
   const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
   const nav = document.getElementById('site-nav');

   if (toggle && nav) {
      const close = () => {
         nav.removeAttribute('data-open');
         toggle.setAttribute('aria-expanded', 'false');
         toggle.setAttribute('aria-label', 'Open menu');
      };
      const open = () => {
         nav.setAttribute('data-open', '');
         toggle.setAttribute('aria-expanded', 'true');
         toggle.setAttribute('aria-label', 'Close menu');
      };

      toggle.addEventListener('click', () => {
         nav.hasAttribute('data-open') ? close() : open();
      });

      // tapping a destination closes the menu
      nav.addEventListener('click', (e) => {
         if ((e.target as HTMLElement).closest('a')) close();
      });

      // Escape closes; focus returns to the toggle
      document.addEventListener('keydown', (e) => {
         if (e.key === 'Escape' && nav.hasAttribute('data-open')) {
            close();
            toggle.focus();
         }
      });

      // crossing back to the desktop layout resets state
      const desktop = window.matchMedia('(min-width: 631px)');
      desktop.addEventListener('change', (e) => {
         if (e.matches) close();
      });
   }
</script>
