---
// A single copyable install command; the copy button lives here only, so it stays off every other code block.
import { Code } from 'astro:components';
interface Props {
   command: string;
}
const { command } = Astro.props;
---

<div class="install-command">
   <Code code={command} lang="bash" theme="night-owl" />
   <button type="button" class="ic-copy" data-command={command} aria-label="Copy install command">
      <svg
         class="ic-icon ic-icon-copy"
         viewBox="0 0 24 24"
         width="14"
         height="14"
         fill="none"
         stroke="currentColor"
         stroke-width="2"
         stroke-linecap="round"
         stroke-linejoin="round"
         aria-hidden="true"
      >
         <rect x="9" y="9" width="11" height="11" rx="2"></rect>
         <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <svg
         class="ic-icon ic-icon-check"
         viewBox="0 0 24 24"
         width="14"
         height="14"
         fill="none"
         stroke="currentColor"
         stroke-width="2"
         stroke-linecap="round"
         stroke-linejoin="round"
         aria-hidden="true"
      >
         <path d="M20 6 9 17l-5-5"></path>
      </svg>
   </button>
</div>

<style>
   .install-command {
      display: inline-block;
      position: relative;
      max-width: 100%;
   }
   .install-command :global(pre.astro-code) {
      margin: 0;
      border-radius: 8px;
      padding: 0.7rem 3.6rem 0.7rem 1rem;
      font-size: 0.84rem;
      border: 1px solid rgba(255, 189, 110, 0.25);
      overflow-x: auto;
   }
   .ic-copy {
      position: absolute;
      top: 50%;
      right: 0.5rem;
      transform: translateY(-50%);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--white-soft);
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 5px;
      padding: 0.35rem;
      cursor: pointer;
      transition:
         background 0.15s,
         color 0.15s,
         border-color 0.15s;
   }
   .ic-copy:hover {
      background: rgba(255, 189, 110, 0.18);
      color: var(--gold-bright);
      border-color: var(--gold);
   }
   .ic-icon {
      display: block;
   }
   .ic-icon-check {
      display: none;
   }
   .ic-copy.is-copied .ic-icon-copy {
      display: none;
   }
   .ic-copy.is-copied .ic-icon-check {
      display: block;
      color: var(--gold-bright);
   }
</style>

<script>
   for (const btn of document.querySelectorAll<HTMLButtonElement>('.ic-copy')) {
      btn.addEventListener('click', async () => {
         const cmd = btn.dataset.command ?? '';
         try {
            await navigator.clipboard.writeText(cmd);
            btn.classList.add('is-copied');
            btn.setAttribute('aria-label', 'Copied');
            setTimeout(() => {
               btn.classList.remove('is-copied');
               btn.setAttribute('aria-label', 'Copy install command');
            }, 1400);
         } catch {
            btn.setAttribute('aria-label', 'Copy failed');
            setTimeout(() => btn.setAttribute('aria-label', 'Copy install command'), 1400);
         }
      });
   }
</script>
