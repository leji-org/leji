---
import fs from 'node:fs';
import path from 'node:path';
import { Code } from 'astro:components';
import Doc from '../layouts/Doc.astro';
import SupportedRuntimes from '../components/SupportedRuntimes.astro';
import InstallTabs from '../components/InstallTabs.astro';

// Single-sourced from the SDK's canonical CLI spec; the terminal `leji --help`
// renders from the same file, so this page and the tool cannot disagree.
const cli = JSON.parse(fs.readFileSync(path.resolve(process.cwd(), '../../packages/sdk/cli.json'), 'utf-8'));
const slug = (name: string) => name.replace(/\s+/g, '-');

// Render inline `code` spans from the canonical copy: split on backticks, the
// odd segments are code. Returns plain segments (text stays an escaped string
// child, never set:html) so this is safe for the controlled cli.json copy.
const segments = (s: string) => s.split('`').map((part, i) => ({ part, code: i % 2 === 1 }));
---

<Doc
   title="CLI reference · Leji"
   description="Every leji command: validate, index, changelog, freshness, conformance, viewer, viewer serve, viewer build, view, detect, adopt, init, start, ci, and agent, with flags, exit codes, and examples."
>
   <h1>CLI reference</h1>
   <p class="sp-lede">{cli.summary}</p>
   <p>
      Install it below in whichever runtime your toolchain or CI uses; the command surface is identical across all
      three. Every command takes <code>--root &lt;dir&gt;</code>; the reporting commands also emit machine-readable <code
         >--json</code
      >. The same spec generates both this reference and <code>leji --help</code>. Working through an agent? The same
      validation and conformance are available as <a href="/mcp/">MCP tools</a>.
   </p>

   <div class="runtimes-block">
      <SupportedRuntimes />
   </div>

   <div class="cli-install">
      <p class="cli-install-label">Install</p>
      <div class="cli-install-tabs"><InstallTabs /></div>
      <p class="cli-install-next">
         New to Leji? The <a href="/quickstart/">Quickstart</a> walks through installing, then scaffolding or adopting your
         first context layer.
      </p>
   </div>

   <div class="cli-code"><Code code={cli.usage} lang="bash" theme="night-owl" /></div>

   <aside class="cli-onboarding">
      <h2>Agent onboarding</h2>
      <p>
         Bring a repository into a context layer.
         <a href="#adopt"><code>leji adopt</code></a> maps an existing repo and migrates <code>CLAUDE.md</code> /
         <code>AGENTS.md</code> into the context layer (with <code>--wire-adapters</code> it converts those existing entrypoints
         into one-line redirects); <a href="#init"><code>leji init</code></a> scaffolds a new one with an onboarding brief
         for your agent to fill; <a href="#detect"><code>leji detect</code></a> finds installed hosts, and <a
            href="#start"><code>leji start</code></a
         > opens one in the layer. Preview <code>init</code> or <code>adopt</code> with <code>--dry-run</code>.
      </p>
   </aside>

   <h2>Commands</h2>
   <table class="cli-table cmd-table">
      <tbody>
         {
            cli.commands.map((c: any) => (
               <tr>
                  <td>
                     <a href={`#${slug(c.name)}`}>
                        <code>{c.name}</code>
                     </a>
                  </td>
                  <td>{segments(c.summary).map((s) => (s.code ? <code>{s.part}</code> : s.part))}</td>
               </tr>
            ))
         }
      </tbody>
   </table>

   <h2>Exit codes</h2>
   <table class="cli-table">
      <thead>
         <tr><th>Code</th><th>Meaning</th></tr>
      </thead>
      <tbody>
         {
            cli.exitCodes.map((e: any) => (
               <tr>
                  <td>
                     <code>{e.code}</code>
                  </td>
                  <td>{e.meaning}</td>
               </tr>
            ))
         }
      </tbody>
   </table>

   <h2>Global options</h2>
   <table class="cli-table">
      <tbody>
         {
            cli.globalOptions.map((o: any) => (
               <tr>
                  <td>
                     <code>{o.flags}</code>
                  </td>
                  <td>{o.summary}</td>
               </tr>
            ))
         }
      </tbody>
   </table>

   {
      cli.commands.map((c: any) => (
         <section class="cmd">
            <h2 id={slug(c.name)}>
               <code>leji {c.name}</code>
            </h2>
            <p>{segments(c.description).map((s) => (s.code ? <code>{s.part}</code> : s.part))}</p>
            {c.details?.length > 0 && (
               <ul class="cmd-details">
                  {c.details.map((d: string) => (
                     <li>{segments(d).map((s) => (s.code ? <code>{s.part}</code> : s.part))}</li>
                  ))}
               </ul>
            )}
            <div class="cli-code">
               <Code code={c.usage} lang="bash" theme="night-owl" />
            </div>
            {c.options.length > 0 && (
               <table class="cli-table">
                  <tbody>
                     {c.options.map((o: any) => (
                        <tr>
                           <td>
                              <code>{o.flags}</code>
                           </td>
                           <td>{o.summary}</td>
                        </tr>
                     ))}
                  </tbody>
               </table>
            )}
            <p class="ex-label">{c.examples.length > 1 ? 'Examples' : 'Example'}</p>
            <div class="cli-code">
               <Code code={c.examples.join('\n')} lang="bash" theme="night-owl" />
            </div>
         </section>
      ))
   }
</Doc>

<style>
   .cli-onboarding {
      margin: 1.8rem 0 0.6rem;
      padding: 1.1rem 1.3rem;
      border-left: 3px solid var(--gold);
      background: rgba(255, 189, 110, 0.08);
      border-radius: 0 8px 8px 0;
   }
   .cli-onboarding h2 {
      margin: 0 0 0.4rem;
      font-size: 1.1rem;
   }
   .cli-onboarding p {
      margin: 0;
      color: var(--ink-soft);
   }

   /* command names read like the schema links: blue pill, gold link underline,
      not bold (each still jumps to its detail section) */
   .cmd-table td a code {
      color: var(--blue);
   }
   .cmd-table td a:hover code {
      background: rgba(34, 63, 147, 0.13);
   }

   .runtimes-block {
      margin-bottom: 1.2rem;
   }

   /* on-page install: same single-sourced tabs as the hero/quickstart, in a
      dark wrapper because InstallTabs is styled for a dark background */
   .cli-install {
      margin: 0 0 1.8rem;
   }
   .cli-install-label {
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--ink-soft);
      margin: 0 0 0.6rem;
   }
   .cli-install-tabs {
      background: var(--blue-deep);
      border-radius: 12px;
      box-shadow: 0 14px 40px rgba(22, 41, 96, 0.14);
      overflow: hidden;
   }
   .cli-install-next {
      margin: 0.9rem 0 0;
      font-size: 0.9rem;
      color: var(--ink-soft);
   }

   .cli-table {
      width: 100%;
      border-collapse: collapse;
      margin: 0.8rem 0 0;
   }
   .cli-table th {
      text-align: left;
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--ink-soft);
      padding: 0.4rem 0.9rem 0.4rem 0;
      border-bottom: 1px solid var(--line);
   }
   .cli-table td {
      padding: 0.5rem 0.9rem 0.5rem 0;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
      color: var(--ink-soft);
   }
   .cli-table td:first-child {
      white-space: nowrap;
   }
   .cli-table td code {
      color: var(--blue-deep);
      font-size: 0.85em;
   }

   .cmd {
      margin-top: 2.6rem;
      padding-top: 0.4rem;
   }
   .cmd h2 {
      scroll-margin-top: 1.5rem;
   }
   .cmd h2 code {
      color: var(--blue-deep);
      background: none;
      padding: 0;
   }
   /* per-command sub-points: quiet bullets with a small gold marker, tied to the
      same accent the onboarding aside uses; the code spans inherit prose styling */
   .cmd-details {
      margin: 0.9rem 0 0;
      padding: 0;
      list-style: none;
   }
   .cmd-details li {
      position: relative;
      padding-left: 1.1rem;
      margin: 0.5rem 0;
      color: var(--ink-soft);
      line-height: 1.6;
   }
   .cmd-details li::before {
      content: '';
      position: absolute;
      left: 0.1rem;
      top: 0.62em;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--gold);
   }
   .ex-label {
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--ink-soft);
      margin: 1.1rem 0 0;
   }
   .cli-code :global(.astro-code) {
      background: var(--blue-deep) !important;
      border-radius: 10px;
      padding: 1rem 1.2rem;
      font-size: var(--code-fz);
      line-height: 1.6;
      margin-top: 0.6rem;
   }
</style>
