---
import fs from 'node:fs';
import path from 'node:path';
import { Code } from 'astro:components';
import SchemaFields from '../../components/SchemaFields.astro';
import Doc from '../../layouts/Doc.astro';

const ROOT = path.resolve(process.cwd(), '../..');
const SCHEMA_DIR = path.join(ROOT, 'schemas');

// Each schema gets a real validating instance from the monorepo example; frontmatter artifacts use the actual markdown file, since that's what tooling reads.
const EXAMPLES: Record<string, { file: string; lang: string; label: string; note: string }> = {
   'context-manifest': {
      file: 'examples/monorepo/leji.json',
      lang: 'json',
      label: 'leji.json',
      note: 'A conforming manifest at a repository root.',
   },
   'context-index': {
      file: 'examples/monorepo/docs/context-index.json',
      lang: 'json',
      label: 'context-index.json',
      note: 'A generated context index, regenerated by the SDK on change.',
   },
   'context-changelog': {
      file: 'examples/monorepo/docs/context-changelog.json',
      lang: 'json',
      label: 'context-changelog.json',
      note: 'A machine-readable changelog of context layer changes.',
   },
   'agent-profile': {
      file: 'examples/monorepo/docs/agents/thought-partner.md',
      lang: 'markdown',
      label: 'thought-partner.md',
      note: 'A conforming agent profile. This schema validates the YAML frontmatter; the markdown body beneath it is free-form prose.',
   },
   'decision-record': {
      file: 'examples/monorepo/docs/decisions/0001-adopt-leji.md',
      lang: 'markdown',
      label: '0001-adopt-leji.md',
      note: 'A conforming decision record. This schema validates the YAML frontmatter; the markdown body carries context, decision, and consequences.',
   },
};

export async function getStaticPaths() {
   const dir = path.resolve(process.cwd(), '../../schemas');
   return fs
      .readdirSync(dir)
      .filter((f) => f.endsWith('.schema.json'))
      .map((file) => ({ params: { name: file.replace(/\.schema\.json$/, '') } }));
}

const { name } = Astro.params;
const file = `${name}.schema.json`;
const raw = fs.readFileSync(path.join(SCHEMA_DIR, file), 'utf-8');
const schema = JSON.parse(raw);
const ex = EXAMPLES[name!];
const exampleRaw = ex ? fs.readFileSync(path.join(ROOT, ex.file), 'utf-8').trimEnd() : null;
---

<Doc title={`${schema.title ?? file} · Leji`}>
   <h1>{schema.title ?? file}</h1>
   {schema.description && <p class="sp-lede">{schema.description}</p>}

   <p class="schema-meta">
      <strong>Canonical <code>$id</code>:</strong>
      <code>{schema.$id}</code><br />
      <strong>Raw file:</strong>
      <a href={`/schemas/v1.0/${file}`}><code>{file}</code></a>
   </p>

   <h2>Fields</h2>
   <SchemaFields schema={schema} />

   <h2>Schema and example</h2>
   <div class="tabs">
      <input type="radio" name="schema-tabs" id="tab-schema" checked />
      <input type="radio" name="schema-tabs" id="tab-example" />
      <div class="tab-bar">
         <label for="tab-schema">Schema</label>
         {
            ex && (
               <label for="tab-example">
                  Example · <code>{ex.label}</code>
               </label>
            )
         }
      </div>
      <div class="tab-panels">
         <div class="tab-panel" data-panel="schema">
            <Code code={raw.trimEnd()} lang="json" theme="night-owl" wrap />
         </div>
         {
            ex && exampleRaw && (
               <div class="tab-panel" data-panel="example">
                  <p class="example-note">{ex.note}</p>
                  <Code code={exampleRaw} lang={ex.lang} theme="night-owl" wrap />
               </div>
            )
         }
      </div>
   </div>

   <p class="all-schemas"><a href="/schemas/">← All schemas</a></p>
</Doc>

<style>
   .schema-meta {
      line-height: 2;
   }

   /* CSS-only tabs: hidden radios drive the active panel, no JavaScript. */
   .tabs {
      margin-top: 1rem;
   }
   .tabs > input {
      position: absolute;
      opacity: 0;
      width: 0;
      height: 0;
      pointer-events: none;
   }
   .tab-bar {
      display: flex;
      gap: 0.3rem;
      border-bottom: 1px solid var(--line);
   }
   .tab-bar label {
      font-family: var(--mono);
      font-size: 0.76rem;
      letter-spacing: 0.04em;
      color: var(--ink-soft);
      padding: 0.5rem 0.9rem;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      transition: color 0.15s;
   }
   .tab-bar label code {
      background: none;
      padding: 0;
      font-size: 1em;
      color: inherit;
   }
   .tab-bar label:hover {
      color: var(--blue);
   }
   #tab-schema:checked ~ .tab-bar label[for='tab-schema'],
   #tab-example:checked ~ .tab-bar label[for='tab-example'] {
      color: var(--blue-deep);
      border-bottom-color: var(--gold);
   }
   #tab-schema:focus-visible ~ .tab-bar label[for='tab-schema'],
   #tab-example:focus-visible ~ .tab-bar label[for='tab-example'] {
      outline: 2px solid var(--gold-bright);
      outline-offset: 2px;
   }
   .tab-panel {
      display: none;
   }
   #tab-schema:checked ~ .tab-panels [data-panel='schema'],
   #tab-example:checked ~ .tab-panels [data-panel='example'] {
      display: block;
   }
   .example-note {
      font-size: 0.9rem;
      color: var(--ink-soft);
      margin: 0.9rem 0 0;
   }
   .tab-panels :global(.astro-code) {
      background: var(--blue-deep) !important;
      border-radius: 10px;
      padding: 1.2rem 1.4rem;
      font-size: var(--code-fz);
      line-height: 1.6;
      margin-top: 0.9rem;
   }
   .all-schemas {
      margin-top: 2rem;
   }
</style>
