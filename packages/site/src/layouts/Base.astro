---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/source-serif-4';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';

const {
   title = 'Leji: an open specification for the shared context layer',
   description = 'Leji defines the shared context layer of AI-native teams: one versioned, repo-owned context layer of how a team thinks, read by people and AI agents on every task.',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og.png', Astro.site);

// Content Security Policy for this static site. Kept in lockstep with
// public/_headers so the policy holds on hosts that honour _headers (Netlify,
// Cloudflare Pages) and, via the <meta> tag below, on hosts that ignore it.
// 'unsafe-inline' covers the small inline nav scripts and inline styles; the
// site loads no third-party origins.
const CSP =
   "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; " +
   "script-src 'self' 'unsafe-inline'; font-src 'self'; base-uri 'self'; " +
   "frame-ancestors 'none'; object-src 'none'";

// Sitewide structured data: the Leji specification project and its publisher.
// Public information only, mirroring what already appears on the site.
const siteLd = {
   '@context': 'https://schema.org',
   '@graph': [
      {
         '@type': 'WebSite',
         '@id': 'https://leji.org/#website',
         name: 'Leji',
         description:
            'Leji is an open specification for the shared context layer of AI-native teams: one versioned, repo-owned layer of how a team thinks, read by people and AI agents on every task.',
         url: 'https://leji.org',
         inLanguage: 'en',
         publisher: { '@id': 'https://leji.org/#organization' },
      },
      {
         '@type': 'Organization',
         '@id': 'https://leji.org/#organization',
         name: 'Meteor Dreams',
         url: 'https://leji.org',
      },
   ],
};
---

<!doctype html>
<html lang="en">
   <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1" />
      <meta http-equiv="Content-Security-Policy" content={CSP} />
      <meta http-equiv="X-Content-Type-Options" content="nosniff" />
      <meta name="referrer" content="strict-origin-when-cross-origin" />
      <title>{title}</title>
      <meta name="description" content={description} />
      <link rel="canonical" href={canonical} />
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
      <link rel="sitemap" href="/sitemap-index.xml" />
      <meta property="og:title" content={title} />
      <meta property="og:description" content={description} />
      <meta property="og:type" content="website" />
      <meta property="og:url" content={canonical} />
      <meta property="og:site_name" content="Leji" />
      <meta property="og:image" content={ogImage} />
      <meta property="og:image:width" content="1200" />
      <meta property="og:image:height" content="630" />
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content={title} />
      <meta name="twitter:description" content={description} />
      <meta name="twitter:image" content={ogImage} />
      <script type="application/ld+json" set:html={JSON.stringify(siteLd)} />
   </head>
   <body>
      <slot />
   </body>
</html>
